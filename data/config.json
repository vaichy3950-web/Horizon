{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-chat",
    "api_key_env": "OPENAI_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0
  },
  "sources": {
    "github": [],
    "hackernews": {
      "enabled": false
    },
    "rss": [
      {
        "name": "懂球帝 - 足球资讯",
        "url": "https://rsshub.app/dongqiudi/daily",
        "enabled": true,
        "category": "足球"
      },
      {
        "name": "少数派 - 抽屉里的旅行",
        "url": "https://sspai.com/feed",
        "enabled": true,
        "category": "旅游"
      },
      {
        "name": "36氪 - 城市与建筑",
        "url": "https://36kr.com/feed",
        "enabled": true,
        "category": "建筑施工"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "Soccer",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 100
        },
        {
          "subreddit": "Travel",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        }
      ],
      "fetch_comments": 2
    }
  },
  "filtering": {
    "ai_score_threshold": 0.0,
    "time_window_hours": 72
  },
  "webhook": {
    "enabled": false
  }
}